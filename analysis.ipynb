      <div class="editor flex lazy-editor" style=""><pre tabindex="0" class="lazy-virtualized" style="font-size: 14px; line-height: 19px;"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab colab colab" data-lang="notebook-python"><span><span class="mtk19">from</span><span class="mtk1">&nbsp;sklearn.ensemble&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;StackingRegressor</span></span><br><span><span class="mtk19">from</span><span class="mtk1">&nbsp;sklearn.linear_model&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;Ridge</span></span><br><span><span></span></span><br><span><span class="mtk1">stack_model&nbsp;=&nbsp;StackingRegressor(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;estimators=[</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(</span><span class="mtk21">"lr"</span><span class="mtk1">,&nbsp;LinearRegression()),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(</span><span class="mtk21">"rf"</span><span class="mtk1">,&nbsp;RandomForestRegressor(n_estimators=</span><span class="mtk12">100</span><span class="mtk1">,&nbsp;random_state=</span><span class="mtk12">42</span><span class="mtk1">)),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(</span><span class="mtk21">"gbr"</span><span class="mtk1">,&nbsp;GradientBoostingRegressor(random_state=</span><span class="mtk12">42</span><span class="mtk1">)),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(</span><span class="mtk21">"xgb"</span><span class="mtk1">,&nbsp;XGBRegressor(random_state=</span><span class="mtk12">42</span><span class="mtk1">,&nbsp;objective=</span><span class="mtk21">"reg:squarederror"</span><span class="mtk1">))</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;final_estimator=Ridge()</span></span><br><span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk1">stack_model.fit(X_train,&nbsp;y_train)</span></span><br><span><span></span></span><br><span><span class="mtk1">stack_pred&nbsp;=&nbsp;stack_model.predict(X_test)</span></span><br><span><span></span></span><br><span><span class="mtk1">stack_mae&nbsp;=&nbsp;mean_absolute_error(y_test,&nbsp;stack_pred</span><span class="mtk1">)</span></span><br><span><span class="mtk1">stack_rmse&nbsp;=&nbsp;np.sqrt(mean_squared_error(y_test,&nbsp;st</span><span class="mtk1">ack_pred))</span></span><br><span><span class="mtk1">stack_r2&nbsp;=&nbsp;r2_score(y_test,&nbsp;stack_pred)</span></span><br><span><span></span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk21">"Stacking&nbsp;Regressor"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk21">"MAE:"</span><span class="mtk1">,&nbsp;stack_mae)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk21">"RMSE:"</span><span class="mtk1">,&nbsp;stack_rmse)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk21">"R2:"</span><span class="mtk1">,&nbsp;stack_r2)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$207927773$-->Start coding or <span tabindex="0" role="button" class="link">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
